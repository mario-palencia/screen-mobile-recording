{
  "manifest_version": 3,
  "name": "Mobile Screen Recorder: Frame, GIF & MP4",
  "version": "1.0.2",
  "description": "Record browser in mobile view with iPhone frame. Auto-export MP4, WebM or GIF. Works in Incognito. For app demos & presentations.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabCapture",
    "offscreen",
    "downloads",
    "system.display"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}

